# ── Water System Environment Config ──────────────────────────────────────────
# Copy this to .env and fill in values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Raspberry Pi): leave as default SQLite
DATABASE_URL=sqlite+aiosqlite:///./water_system.db

# Cloud (VPS with PostgreSQL): uncomment and fill in
# DATABASE_URL=postgresql+asyncpg://wateruser:yourpassword@localhost:5432/water_system

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Arduino Serial ────────────────────────────────────────────────────────────
# Linux (Raspberry Pi): /dev/ttyUSB0 or /dev/ttyACM0
# Windows (dev): COM3
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=9600

# ── Email Alerts (optional) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_RECIPIENTS=official1@barangay.ph,official2@barangay.ph

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production
PORT=8000
FRONTEND_URL=http://localhost:5173
